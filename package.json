{
	"name": "website",
	"version": "0.1.0",
	"author": "killbasa <contact@killbasa.com>",
	"license": "MIT",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/killbasa/website.git"
	},
	"homepage": "https://github.com/killbasa/website",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"sync": "svelte-kit sync",
		"check": "npm run sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"ci": "npm run check && npm run lint && npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/node": "^26.1.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.5",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.3",
		"typescript": "6.0.3",
		"vite": "8.1.5",
		"wrangler": "^4.111.0"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --no-errors-on-unmatched"
		],
		"*.md": [
			"prettier --write --log-level=warn \"**/*.md\""
		]
	},
	"engines": {
		"node": "26.x"
	},
	"packageManager": "yarn@4.17.1"
}
