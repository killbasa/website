{
	"name": "website",
	"version": "0.1.0",
	"author": "killbasa <contact@killbasa.com>",
	"license": "MIT",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/killbasa/website.git"
	},
	"homepage": "https://github.com/killbasa/website",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"sync": "svelte-kit sync",
		"check": "npm run sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint --fix",
		"format": "prettier --write .",
		"ci": "npm run check && npm run lint && npm run build"
	},
	"devDependencies": {
		"@killbasa/eslint-config": "^3.1.6",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.0",
		"eslint": "10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.55.8",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "6.0.3",
		"vite": "8.0.13",
		"wrangler": "^4.92.0"
	},
	"resolutions": {
		"eslint": "9.39.2"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"eslint --fix"
		],
		"*.{js,ts,json,html}": [
			"prettier --write --log-level=warn \"**/*.{js,ts,json,html}\""
		]
	},
	"engines": {
		"node": "26.x"
	},
	"packageManager": "yarn@4.14.1",
	"volta": {
		"node": "26.1.0"
	}
}
